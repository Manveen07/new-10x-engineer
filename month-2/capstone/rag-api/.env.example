# App Settings
APP_NAME=month2-rag-api
APP_ENV=local
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://month2:month2@localhost:5432/month2

# Redis
REDIS_URL=redis://localhost:6379/1

# Security
SECRET_KEY=generate_a_secure_random_string_for_local_dev
JWT_ALGORITHM=HS256

# LLM Providers
DEFAULT_PROVIDER=mock
DEFAULT_MODEL=mock-chat
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=

# RAG Defaults
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-embedding
EMBEDDING_DIMENSIONS=1536
RERANKER_PROVIDER=mock
RERANKER_MODEL=mock-reranker
VECTOR_BACKEND=pgvector
LEXICAL_BACKEND=postgres_fts
DEFAULT_TOP_K=10
DEFAULT_RERANK_TOP_K=5
RRF_K=60
SEMANTIC_THRESHOLD=0.93

# Observability
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
